{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "description": "E-commerce purchase server: credit balances, purchases and refunds, backed by the external Customers/Products/Shipments API.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node --experimental-sqlite dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "ts-node-dev": "^2.0.0"
  }
}
